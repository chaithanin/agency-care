// Agency Care Enterprise — Prisma schema
// MVP เฟส 1: users / employees / agencies / assignments / visit (plan, checkin, photo, report)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================
enum UserRole {
  manager     // ผู้จัดการ — สูงสุด เข้าถึงได้ทุกอย่าง
  super_admin // จัดการทั้งระบบ
  admin       // ดูแลองค์กร สลับ role ได้ + Impersonate
  closer      // หัวหน้าทีม — เห็นเฉพาะทีมตัวเอง
  sales       // เซลส์ภาคสนาม — เห็นงานตัวเอง
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskStatus {
  pending
  in_progress
  done
  overdue
}

enum TaskType {
  manual
  auto
  ai
}

enum AgencyLevel {
  VIP // เยี่ยม 8 ครั้ง/เดือน
  A   // เยี่ยม 4 ครั้ง/เดือน
  B   // เยี่ยม 2 ครั้ง/เดือน
  C   // เยี่ยม 1 ครั้ง/เดือน
  D   // เยี่ยม 1 ครั้ง/3 เดือน
}

enum AgencyStatus {
  active
  inactive
}

enum VisitStatus {
  pending               // รอเข้าเยี่ยม (สร้างแผนแล้ว)
  waiting_confirmation  // รอโทร confirm (วันก่อนเยี่ยม)
  confirmed             // Agency ยืนยันนัดแล้ว
  rescheduled           // Agency ขอเลื่อนนัด
  on_route              // Sale กำลังเดินทาง
  done                  // เข้าเยี่ยมสำเร็จ
  postponed             // เลื่อน (ค่าเดิม — backward compat)
  cancelled             // ยกเลิก
}

enum CallConfirmResult {
  confirmed  // Agency รับสาย + ยืนยันนัด
  rescheduled // Agency ขอเลื่อน
  no_answer  // โทรไม่ติด
  cancelled  // Agency ยกเลิก
}

enum AssignmentPlanStatus {
  draft            // AI สร้างเสนอ — ยังแก้ไขได้
  pending_approval // ส่งอนุมัติแล้ว — รอ Admin/Closer
  approved         // อนุมัติแล้ว — รอ Publish
  published        // เผยแพร่ + แจกงานให้ Sale แล้ว
  active           // กำลังดำเนินงาน (เดือนปัจจุบัน)
  closed           // ปิดเดือนแล้ว
}

enum PhotoPhase {
  before // ก่อนเข้า
  during // ระหว่างเข้า
  after // หลังเข้า
  office // หน้าออฟฟิศ Agency
  activity // กิจกรรมที่ทำ
  material // สื่อที่ติดตั้ง
  selfie // selfie คู่ผู้ดูแล Agency
}

enum AuditAction {
  create
  update
  delete
  login
  impersonate
  assign
  unassign
  restore
  approve
}

// Phase 5: ตำแหน่งพนักงาน
enum EmployeePosition {
  sales // เซลส์ — ดูแล agency, เข้าเยี่ยม, หาลูกค้าใหม่, ทำยอดขาย
  closer // Closer — ปิดการขาย, ตามผลงาน, ดูแลคุณภาพงาน
}

// Phase 5: ชนิดงานในตารางรายวัน
enum ScheduleItemType {
  meeting // ประชุมทีม
  visit // เข้าเยี่ยม agency
  followup // ติดตามงาน
  newAgency // หา/เพิ่ม agency ใหม่
  report // บันทึกรายงาน
  office // งานในออฟฟิศ
  other
}

// ============================================================
// 1) users — บัญชีเข้าระบบ (auth)
// ============================================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(sales)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // multi-role: สลับ role ใน session ได้ (Admin ↔ Closer ↔ Sales)
  activeRole      UserRole @default(sales) @map("active_role")
  additionalRoles String[] @default([]) @map("additional_roles") // role เพิ่มเติมที่สลับได้

  // เซลส์ 1 คน = 1 user (โปรไฟล์ field-sales อยู่ใน Employee)
  employee       Employee?
  auditLogs      AuditLog[]
  notifications  InAppNotification[]
  createdPlans   AssignmentPlan[]    @relation("PlanCreatedBy")
  approvedPlans  AssignmentPlan[]    @relation("PlanApprovedBy")
  planVersions   PlanVersion[]
  leaveApprovals LeaveRequest[]      @relation("LeaveApprovedBy")
  createdPRs     PurchaseRequest[]   @relation("PrCreatedBy")
  approvedPRs    PurchaseRequest[]   @relation("PrApprover")
  prComments     PrComment[]         @relation("PrComment")
  prActivities   PrActivity[]        @relation("PrActivity")
  docCreated     DocumentRecord[] @relation("DocCreator")
  docApproved    DocumentRecord[] @relation("DocApprover")
  docCloser      DocumentRecord[] @relation("DocCloser")
  docSupervisor  DocumentRecord[] @relation("DocSupervisor")
  docSignatures  DocSignature[]   @relation("DocSignatureUser")
  docAuditLogs   DocAuditLog[]    @relation("DocAuditActor")
  docVersionsCreated  DocVersion[] @relation("DocVersionCreator")
  docVersionsApproved DocVersion[] @relation("DocVersionApprover")
  expenseApprovals    ExpenseReport[] @relation("ExpenseApprover")
  trainingsCreated    TrainingRecord[] @relation("TrainingCreator")
  evaluationsGiven    EmployeeEvaluation[] @relation("EvaluationCreator")
  agencyScoresCreated AgencyScore[] @relation("AgencyScoreCreator")
  broadcastsCreated    Broadcast[]         @relation("BroadcastCreator")
  broadcastsApproved   Broadcast[]         @relation("BroadcastApprover")
  broadcastTemplates   BroadcastTemplate[] @relation("TemplateCreator")
  broadcastLogs        BroadcastLog[]      @relation("BroadcastLogUser")

  @@map("users")
}

// ============================================================
// 2) employees — โปรไฟล์พนักงาน/เซลส์ภาคสนาม
// ============================================================
model Employee {
  id        String   @id @default(cuid())
  userId    String?  @unique @map("user_id") // ผูกกับบัญชี login (ถ้ามี)
  code       String   @unique // รหัสพนักงาน เช่น SALE-001
  name       String
  phone      String?
  zone       String? // โซน/พื้นที่ดูแล
  position   EmployeePosition @default(sales) // Phase 5: sales / closer
  teamId     String?  @map("team_id") // Phase 5: สังกัดทีม
  inTraining Boolean  @default(false) @map("in_training") // Phase 5: กำลังเทรน (โหลดงานเบากว่า)
  lineUserId String?  @map("line_user_id") // ผูก LINE เพื่อรับแจ้งเตือน
  isActive   Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  team        Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  assignments AgencyAssignment[]
  visitPlans  VisitPlan[]
  checkins    VisitCheckin[]
  monthlyPlans   MonthlyPlan[]
  kpiTargets     KpiTarget[]
  dailySchedules DailySchedule[]
  addedAgencies  Agency[]        @relation("AgencyAddedBy")
  closerAgencies Agency[]        @relation("AgencyCloser")
  tasks          Task[]
  planVersionItems PlanVersionItem[]
  leaveRequests  LeaveRequest[]
  notificationLogs NotificationLog[]
  responsiblePRs PurchaseRequest[]   @relation("PrResponsible")
  documents DocumentRecord[]
  expenses      ExpenseReport[]
  trainings     TrainingRecord[]
  evaluations          EmployeeEvaluation[]
  broadcastRecipients  BroadcastRecipient[]

  @@index([zone])
  @@index([teamId])
  @@map("employees")
}

// ============================================================
// 3) agencies — เอเจนซี่ (Master)
// ============================================================
model Agency {
  id     String       @id @default(cuid())
  code   String       @unique // รหัส Agency
  name   String
  type   String? // ประเภทร้าน
  level  AgencyLevel  @default(C) // ระดับ A/B/C/D (คุมความถี่เยี่ยม)
  tier   String       @default("gold") // platinum/gold/silver/bronze/new — คุมความถี่เยี่ยม/เดือน
  pipelineStage String  @default("active") @map("pipeline_stage") // Phase 7: new/prospect/onboarding/active/grade_a/at_risk/inactive
  status AgencyStatus @default(active)

  // พื้นที่
  province String? // จังหวัด
  zone     String? // โซน/ภาค

  // ผู้ติดต่อ
  ownerName   String? @map("owner_name") // เจ้าของ
  managerName String? @map("manager_name") // ผู้จัดการ
  phone       String?
  email       String?
  lineId      String? @map("line_id")

  // ข้อมูลจัดกลุ่ม/อ้างอิง (จากไฟล์ Agency List)
  classification    String? // เช่น Rus / Eng / Freelance / Office in Pattaya
  gradeQuality      String? @map("grade_quality") // เกรดคุณภาพ (K)
  gradeRelationship String? @map("grade_relationship") // เกรดความสัมพันธ์ (L) เช่น A = Sold for us
  priority          String? // Priority
  source            String? // Source of Customer
  tags              String? // Extra tags
  lastVisitAt       DateTime? @map("last_visit_at") // วันเข้าเยี่ยมล่าสุด (ก่อนใช้ระบบ)
  addedById         String? @map("added_by_id") // Phase 5: เซลส์ที่เพิ่ม agency นี้เข้าระบบ

  // พิกัด (ใช้ตรวจ check-in)
  latitude       Float?
  longitude      Float?
  geocodeSource  String? @map("geocode_source") // manual = ยืนยันแล้ว, google = auto (ควรตรวจ)

  // ที่อยู่โดยละเอียด
  address     String? // เลขที่/ถนน/ซอย

  // ข้อมูลติดต่อเพิ่มเติม
  website     String? // เว็บไซต์

  // หมายเหตุ
  remark      String? // บันทึกภายในเพิ่มเติม

  // ข้อมูลสัญญา
  agreementActive      Boolean?  @default(false) @map("agreement_active")
  agreementStartDate   DateTime? @map("agreement_start_date") @db.Date
  agreementExpiry      DateTime? @map("agreement_expiry") @db.Date

  // ผลการขาย
  sellsOurProjects     Boolean?  @map("sells_our_projects")
  lastSaleDate         DateTime? @map("last_sale_date") @db.Date
  lastUnitsSold        Int?      @map("last_units_sold")
  totalUnitsSold       Int?      @map("total_units_sold")
  agencyScore          String?   @map("agency_score") // A/B/C/D computed from totalUnitsSold
  agencyScoreNum       Int?      @default(0) @map("agency_score_num") // 0-100 numeric AI score

  // สำนักงาน
  physicalOffice       Boolean?  @map("physical_office")
  numSalesAgents       Int?      @map("num_sales_agents")
  advertisesOurProjects Boolean? @map("advertises_our_projects")
  paidAds              Boolean?  @map("paid_ads")

  // Social Media
  facebook             String?
  instagram            String?
  tiktok               String?
  linkedin             String?
  otherSocial          String?   @map("other_social")

  // Property Focus
  propertyTypes        String[]  @default([]) @map("property_types")
  mainProjects         String[]  @default([]) @map("main_projects")

  // Agency Management
  visitFrequency       Int?      @map("visit_frequency") // 1, 2, or 4 per month
  assignedCloserId     String?   @map("assigned_closer_id")
  approvalStatus       String    @default("active") @map("approval_status") // draft/pending_approval/approved/active

  assignedCloser       Employee? @relation("AgencyCloser", fields: [assignedCloserId], references: [id], onDelete: SetNull)

  profileData Json?   @map("profile_data") // Agency Information Form (structured JSON)

  // รูป (เก็บ url/path)
  photoFront  String? @map("photo_front")
  photoInside String? @map("photo_inside")
  logo        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments AgencyAssignment[]
  visitPlans  VisitPlan[]
  models      Model[] // อุปกรณ์ที่อยู่ที่ร้านนี้ตอนนี้
  modelTxns   ModelTransaction[]
  addedBy       Employee?           @relation("AgencyAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
  scheduleItems DailyScheduleItem[]
  tasks         Task[]
  planVersionItems PlanVersionItem[]
  scores        AgencyScore[]

  @@index([zone])
  @@index([province])
  @@index([status])
  @@index([addedById])
  @@index([assignedCloserId])
  @@index([agreementExpiry])
  @@index([approvalStatus])
  @@map("agencies")
}

// รูปการทำงาน ผูกกับแผนเยี่ยม (อัปโหลดได้ทุกเมื่อ เช่น ตอนเลื่อนนัด)
model VisitWorkPhoto {
  id          String   @id @default(cuid())
  visitPlanId String   @map("visit_plan_id")
  url         String
  caption     String?
  latitude    Float?
  longitude   Float?
  takenAt     DateTime @default(now()) @map("taken_at")

  visitPlan VisitPlan @relation(fields: [visitPlanId], references: [id], onDelete: Cascade)

  @@index([visitPlanId])
  @@map("visit_work_photos")
}

// ============================================================
// 4) agency_assignments — มอบหมาย Agency ให้เซลส์
// ============================================================
model AgencyAssignment {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  employeeId String   @map("employee_id")
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1 agency ผูกกับ 1 เซลส์ได้ครั้งเดียว (ความสัมพันธ์ที่ active)
  @@unique([agencyId, employeeId])
  @@index([employeeId])
  @@map("agency_assignments")
}

// ============================================================
// 5) visit_plans — แผนการเข้าเยี่ยม
// ============================================================
model VisitPlan {
  id         String      @id @default(cuid())
  agencyId   String      @map("agency_id")
  employeeId String      @map("employee_id")
  planDate   DateTime    @map("plan_date") @db.Date // วันที่นัดเยี่ยม
  status     VisitStatus @default(pending)
  note       String?
  actionType      String?  @map("action_type")       // visit/call/invite/orientation/customer/followup_hold/followup_customer/delivery/event/launch/rental
  requestDetails  String?  @map("request_details")   // what the assignee should do
  priority        String   @default("medium")         // high/medium/low
  isRecurring     Boolean  @default(false) @map("is_recurring")
  recurringFreq   String?  @map("recurring_freq")     // weekly/monthly
  recurringUntil  DateTime? @map("recurring_until") @db.Date
  // Pre-site visit confirmation
  callConfirmAt     DateTime?         @map("call_confirm_at")
  callConfirmResult CallConfirmResult? @map("call_confirm_result")
  callNote          String?           @map("call_note")
  rescheduledTo     DateTime?         @map("rescheduled_to") @db.Date
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // เข้าเยี่ยมจริง 1 แผน = 1 check-in + 1 report (MVP)
  checkin VisitCheckin?
  report  VisitReport?

  // เฟส 2: สื่อที่แจก + การขาย ในงานเยี่ยมนี้
  posmTransactions PosmTransaction[]
  salesActivities  SalesActivity[]
  modelTransactions ModelTransaction[]
  workPhotos       VisitWorkPhoto[] // รูปการทำงาน (อัปโหลดได้โดยไม่ต้อง check-in)
  tasks            Task[]

  @@index([employeeId, planDate])
  @@index([agencyId, planDate])
  @@index([planDate, status])
  @@index([actionType])
  @@map("visit_plans")
}

// ============================================================
// 6) visit_checkins — GPS check-in หน้างาน
// ============================================================
model VisitCheckin {
  id          String   @id @default(cuid())
  visitPlanId String   @unique @map("visit_plan_id")
  employeeId  String   @map("employee_id")
  checkinAt   DateTime @default(now()) @map("checkin_at")

  checkOutAt      DateTime? @map("check_out_at") // เวลาเช็กเอาต์
  durationMinutes Int?      @map("duration_minutes") // ระยะเวลาอยู่หน้างาน (นาที)

  // ตำแหน่งที่ผู้ใช้ check-in จริง
  latitude  Float
  longitude Float

  // ผลตรวจระยะห่างจากพิกัด Agency (เมตร)
  distanceMeters Int     @map("distance_meters")
  withinRadius   Boolean @map("within_radius") // ผ่านเงื่อนไขรัศมีหรือไม่
  gpsStatus      String  @default("in_area") @map("gps_status") // in_area / near / out (3 ระดับ)
  accuracyMeters Float?  @map("accuracy_meters") // ความแม่นยำ GPS

  // ผู้เข้าพบ (ผู้ดูแล Agency)
  contactName     String? @map("contact_name")
  contactPosition String? @map("contact_position")
  contactPhone    String? @map("contact_phone")

  // กันปลอมการเช็กอิน
  deviceInfo String?  @map("device_info") // user-agent
  ipAddress  String?  @map("ip_address")
  isMockGps  Boolean  @default(false) @map("is_mock_gps") // ตรวจจับ Fake GPS

  visitPlan VisitPlan    @relation(fields: [visitPlanId], references: [id], onDelete: Cascade)
  employee  Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  photos    VisitPhoto[]

  @@index([employeeId, checkinAt])
  @@map("visit_checkins")
}

// ============================================================
// 7) visit_photos — รูปยืนยันการเข้าเยี่ยม
// ============================================================
model VisitPhoto {
  id        String     @id @default(cuid())
  checkinId String     @map("checkin_id")
  url       String // path/url ของไฟล์
  phase     PhotoPhase @default(during)

  // metadata กันปลอมแปลง
  latitude  Float?
  longitude Float?
  takenAt   DateTime @default(now()) @map("taken_at")

  checkin VisitCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([checkinId])
  @@map("visit_photos")
}

// ============================================================
// 8) visit_reports — รายงานสรุปหลังเข้าเยี่ยม
// ============================================================
model VisitReport {
  id          String   @id @default(cuid())
  visitPlanId String   @unique @map("visit_plan_id")

  // วัตถุประสงค์ (เลือกได้หลายข้อ) เช่น ["visit","close_sale","install_posm"]
  purposes   String[]
  visitType  String? @map("visit_type") // visit_agency | agency_brings_client
  summary    String? // สรุปผล
  problems   String? // ปัญหาที่พบ
  actionPlan String?  @map("action_plan") // แผนต่อไป

  // ผลการเข้าเยี่ยม
  interestLevel String?   @map("interest_level") // high | medium | low
  newLeads      Int?      @map("new_leads")
  nextVisitDate DateTime? @map("next_visit_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  visitPlan VisitPlan @relation(fields: [visitPlanId], references: [id], onDelete: Cascade)

  @@map("visit_reports")
}

// ============================================================
// Follow-up Task — งานติดตามต่อเนื่องหลังเข้าเยี่ยม
// ============================================================
model FollowUpTask {
  id          String    @id @default(cuid())
  agencyId    String    @map("agency_id")
  visitPlanId String?   @map("visit_plan_id") // มาจากการเยี่ยมไหน (ถ้ามี)
  assigneeId  String?   @map("assignee_id") // employee ผู้รับผิดชอบ
  createdById String?   @map("created_by_id")
  title       String
  detail      String?
  dueDate     DateTime? @map("due_date") @db.Date
  status      String    @default("open") // open / done
  doneAt      DateTime? @map("done_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([agencyId])
  @@index([assigneeId, status])
  @@index([status, dueDate])
  @@map("follow_up_tasks")
}

// ============================================================
// 10) posm_items — คลังสื่อส่งเสริมการขาย (POSM master)
// ============================================================
model PosmItem {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  category     String   @default("general") // display | printed | gift | general
  description  String?
  unit         String   @default("ชิ้น")
  stockQty     Int      @default(0) @map("stock_qty")
  reorderPoint Int      @default(0) @map("reorder_point")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions PosmTransaction[]

  @@map("posm_items")
}

// ============================================================
// 11) posm_transactions — แจกสื่อในงานเยี่ยม (ตัดสต็อก)
// ============================================================
model PosmTransaction {
  id          String   @id @default(cuid())
  visitPlanId String   @map("visit_plan_id")
  posmItemId  String   @map("posm_item_id")
  quantity    Int
  createdAt   DateTime @default(now()) @map("created_at")

  visitPlan VisitPlan @relation(fields: [visitPlanId], references: [id], onDelete: Cascade)
  posmItem  PosmItem  @relation(fields: [posmItemId], references: [id], onDelete: Restrict)

  @@index([visitPlanId])
  @@index([posmItemId])
  @@map("posm_transactions")
}

// ============================================================
// 12) products — สินค้า (master)
// ============================================================
model Product {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  price           Float    @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  description     String?
  projectType     String?  @map("project_type")
  unit            String?
  quota           Int?
  marketingLink   String?  @map("marketing_link")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  salesActivities SalesActivity[]

  @@map("products")
}

// ============================================================
// 13) sales_activities — บันทึกการขายในงานเยี่ยม
// ============================================================
model SalesActivity {
  id          String   @id @default(cuid())
  visitPlanId String   @map("visit_plan_id")
  productId   String   @map("product_id")
  qtyOffered  Int      @default(0) @map("qty_offered") // จำนวนที่เสนอ
  qtySold     Int      @default(0) @map("qty_sold") // จำนวนที่ขายได้
  amount      Float    @default(0) // ยอดขายรวม (บาท)
  createdAt   DateTime @default(now()) @map("created_at")

  visitPlan VisitPlan @relation(fields: [visitPlanId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([visitPlanId])
  @@index([productId])
  @@map("sales_activities")
}

// ============================================================
// 14) models — อุปกรณ์/เครื่องเดโม/Display/Stand (เฟส 4)
// ============================================================
enum ModelStatus {
  in_stock // อยู่คลัง
  deployed // ติดตั้งที่ร้าน
  repair // ส่งซ่อม
  lost // สูญหาย
}

model Model {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  category  String? // Display / Demo Unit / Stand / ป้าย
  status    ModelStatus @default(in_stock)

  // ร้านที่อุปกรณ์อยู่ตอนนี้ (ถ้า deployed)
  currentAgencyId String? @map("current_agency_id")
  currentAgency   Agency? @relation(fields: [currentAgencyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions ModelTransaction[]

  @@index([status])
  @@index([currentAgencyId])
  @@map("models")
}

// 15) model_transactions — ประวัติเคลื่อนย้ายอุปกรณ์
model ModelTransaction {
  id          String   @id @default(cuid())
  modelId     String   @map("model_id")
  agencyId    String?  @map("agency_id") // ร้านปลายทาง (deploy) หรือต้นทาง (return)
  visitPlanId String?  @map("visit_plan_id")
  action      String // deploy | return | repair
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  model     Model      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  agency    Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  visitPlan VisitPlan? @relation(fields: [visitPlanId], references: [id], onDelete: SetNull)

  @@index([modelId])
  @@index([agencyId])
  @@map("model_transactions")
}

// ============================================================
// Task — งานทั่วไป (manual / auto / ai)
// ============================================================
model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?    @map("due_date") @db.Date
  priority     TaskPriority @default(medium)
  status       TaskStatus   @default(pending)
  type         TaskType     @default(manual)
  assignedToId String       @map("assigned_to_id")
  agencyId     String?      @map("agency_id")
  visitPlanId  String?      @map("visit_plan_id")
  createdById  String?      @map("created_by_id")
  tag          String?      // call/visit/orientation/customer/followup/delivery/event/etc.
  customerName String?      @map("customer_name")
  isRecurring  Boolean      @default(false) @map("is_recurring")
  recurringFreq String?     @map("recurring_freq")   // daily/weekly
  recurringUntil DateTime?  @map("recurring_until") @db.Date
  doneAt       DateTime?    @map("done_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  assignedTo Employee   @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  agency     Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  visitPlan  VisitPlan? @relation(fields: [visitPlanId], references: [id], onDelete: SetNull)

  @@index([assignedToId, status])
  @@index([status, dueDate])
  @@index([agencyId])
  @@index([tag])
  @@map("tasks")
}

// ============================================================
// InAppNotification — แจ้งเตือนใน app (Notification Center)
// ============================================================
model InAppNotification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String   // visit_reminder|overdue_checkin|task_due|team_summary|org_summary|ai_task
  read      Boolean  @default(false)
  link      String?  // deep link เช่น /tasks หรือ /visits/plans/:id
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("in_app_notifications")
}

// ============================================================
// (infra) audit_logs — บันทึกการกระทำสำคัญ
// ============================================================
model AuditLog {
  id        String      @id @default(cuid())
  userId    String?     @map("user_id")
  action    AuditAction
  entity    String // ชื่อ entity เช่น "agency"
  entityId  String?     @map("entity_id")
  ip        String?
  metadata  Json?       // { before, after, changes: string[] }
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================================
// Phase 5 — Workforce Scheduling & AI Automation
// ============================================================

// ทีม (เช่น ทีม A / ทีม B) รวม sales + closer
model Team {
  id        String   @id @default(cuid())
  code      String   @unique // TEAM-A
  name      String
  zone      String? // โซนหลักที่ทีมดูแล
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members Employee[]

  @@map("teams")
}

// วันหยุดบริษัท (นักขัตฤกษ์ — มีผลทุกคน) — ทำงานทุกวันยกเว้นที่ระบุไว้
model WorkCalendar {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  isHoliday Boolean  @default(false) @map("is_holiday")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("work_calendar")
}

// วันหยุดราย user — แต่ละพนักงานตั้งวันหยุดตัวเองได้ (ให้ทำงาน 24 วัน/เดือน)
model EmployeeHoliday {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("employee_holidays")
}

// แผน/เป้าระดับเดือน ต่อพนักงาน
model MonthlyPlan {
  id              String @id @default(cuid())
  employeeId      String @map("employee_id")
  year            Int
  month           Int // 1-12
  workDayTarget   Int    @default(24) @map("work_day_target")
  visitTarget     Int    @default(0) @map("visit_target") // จำนวนเยี่ยมเป้าทั้งเดือน
  newAgencyTarget Int    @default(2) @map("new_agency_target") // เพิ่ม agency ใหม่
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
  @@index([year, month])
  @@map("monthly_plans")
}

// KPI targets and actuals per employee per period
model KpiTarget {
  id           String   @id @default(cuid())
  employeeId   String   @map("employee_id")
  period       String   // "2026-07" (YYYY-MM)
  // Sale KPI targets
  visitTarget    Int?   @map("visit_target")      // เป้าเยี่ยม/เดือน
  newAgencyTarget Int?  @map("new_agency_target") // เป้า agency ใหม่/เดือน
  salesTarget    Float? @map("sales_target")       // เป้ายอดขาย (บาท)
  followupTarget Int?   @map("followup_target")    // เป้า follow-up tasks
  // Actuals (computed/cached)
  visitActual    Int?   @default(0) @map("visit_actual")
  newAgencyActual Int?  @default(0) @map("new_agency_actual")
  salesActual    Float? @default(0) @map("sales_actual")
  followupActual Int?   @default(0) @map("followup_actual")
  lastCalcAt     DateTime? @map("last_calc_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([period])
  @@map("kpi_targets")
}

// ตารางงานรายวัน ต่อพนักงาน
model DailySchedule {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  inOffice   Boolean  @default(false) @map("in_office") // อยู่ประจำออฟฟิศวันนี้ (กฎคนประจำ)
  status     String   @default("planned") // planned / done
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items    DailyScheduleItem[]

  @@unique([employeeId, date])
  @@index([date])
  @@map("daily_schedules")
}

// รายการงานในตารางรายวัน
model DailyScheduleItem {
  id         String           @id @default(cuid())
  scheduleId String           @map("schedule_id")
  startTime  String?          @map("start_time") // "10:00"
  endTime    String?          @map("end_time") // "12:00"
  type       ScheduleItemType @default(visit)
  agencyId   String?          @map("agency_id") // ถ้าเป็นงานเยี่ยม
  title      String
  done       Boolean          @default(false)
  createdAt  DateTime         @default(now()) @map("created_at")

  schedule DailySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  agency   Agency?       @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([scheduleId])
  @@index([agencyId])
  @@map("daily_schedule_items")
}

// ============================================================
// AI Assignment Planner — แผนแจกงานรายเดือน
// ============================================================

model AssignmentPlan {
  id            String               @id @default(cuid())
  period        String               // "2026-07" — เดือนที่วางแผน
  title         String?              // หัวเรื่อง optional
  status        AssignmentPlanStatus @default(draft)
  note          String?
  totalAgencies Int                  @default(0) @map("total_agencies")
  totalSales    Int                  @default(0) @map("total_sales")
  createdById   String               @map("created_by_id")
  approvedById  String?              @map("approved_by_id")
  approvedAt    DateTime?            @map("approved_at")
  publishedAt   DateTime?            @map("published_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  createdBy  User         @relation("PlanCreatedBy", fields: [createdById], references: [id])
  approvedBy User?        @relation("PlanApprovedBy", fields: [approvedById], references: [id])
  versions   PlanVersion[]

  @@index([period])
  @@index([status])
  @@map("assignment_plans")
}

model PlanVersion {
  id          String   @id @default(cuid())
  planId      String   @map("plan_id")
  versionNo   Int      @map("version_no")   // 1, 2, 3...
  note        String?                        // เหตุผลที่แก้ไข
  isCurrent   Boolean  @default(false) @map("is_current")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  plan      AssignmentPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id])
  items     PlanVersionItem[]

  @@unique([planId, versionNo])
  @@index([planId])
  @@map("plan_versions")
}

model PlanVersionItem {
  id         String  @id @default(cuid())
  versionId  String  @map("version_id")
  agencyId   String  @map("agency_id")
  employeeId String  @map("employee_id")
  isLocked   Boolean @default(false) @map("is_locked")
  note       String?

  version  PlanVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  agency   Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([versionId, agencyId])
  @@index([versionId])
  @@index([agencyId])
  @@index([employeeId])
  @@map("plan_version_items")
}

// ============================================================
// Leave Management — ใบลาพนักงาน
// ============================================================
model LeaveRequest {
  id             String    @id @default(cuid())
  employeeId     String    @map("employee_id")
  leaveType      String    @map("leave_type") // sick/annual/personal/other
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime  @map("end_date") @db.Date
  days           Int
  reason         String?
  status         String    @default("pending") // pending/approved/rejected/cancelled
  approvedById   String?   @map("approved_by_id")
  approvedAt     DateTime? @map("approved_at")
  rejectedReason String?   @map("rejected_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("LeaveApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@map("leave_requests")
}

// ============================================================
// Smart Notification Center
// ============================================================

// การตั้งค่าการแจ้งเตือนรายองค์กร
model NotificationSetting {
  id          String   @id @default(cuid())
  notifType   String   @unique @map("notif_type") // daily_brief|midday|afternoon|evening
  label       String
  isEnabled   Boolean  @default(true) @map("is_enabled")
  cronTime    String   @map("cron_time") // "0 8 * * 1-6" format
  channelLine Boolean  @default(true) @map("channel_line")
  channelEmail Boolean @default(false) @map("channel_email")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

// Log การแจ้งเตือนทุกครั้ง
model NotificationLog {
  id           String    @id @default(cuid())
  notifType    String    @map("notif_type")   // daily_brief|midday|afternoon|evening
  channel      String                          // line|email|in_app
  recipientId  String    @map("recipient_id") // employeeId
  role         String                          // sales|closer|admin
  taskCount    Int       @default(0) @map("task_count")
  overdueCount Int       @default(0) @map("overdue_count")
  messageBody  String?   @map("message_body") @db.Text
  status       String    @default("pending")  // pending|sent|failed|read
  sentAt       DateTime? @map("sent_at")
  readAt       DateTime? @map("read_at")
  errorMsg     String?   @map("error_msg")
  createdAt    DateTime  @default(now()) @map("created_at")

  recipient    Employee  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([notifType, createdAt])
  @@index([recipientId])
  @@index([status])
  @@map("notification_logs")
}

// ============================================================
// PR Tracking Module (Purchase Request)
// ============================================================

model PurchaseRequest {
  id              String    @id @default(cuid())
  prNumber        String    @unique @map("pr_number")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     String    @map("created_by_id")
  department      String
  prType          String    @map("pr_type")
  priority        String    @default("medium") // low|medium|high|urgent
  status          String    @default("draft")  // draft|submitted|waiting_approval|approved|purchasing|ordered|received|completed|cancelled
  title           String
  description     String?   @db.Text
  note            String?   @db.Text
  budgetTotal     Decimal?  @map("budget_total") @db.Decimal(14, 2)
  dueDate         DateTime? @map("due_date") @db.Date
  responsibleId   String?   @map("responsible_id")   // employeeId
  approverId      String?   @map("approver_id")       // userId
  approvedAt      DateTime? @map("approved_at")
  closedAt        DateTime? @map("closed_at")
  cancelReason    String?   @map("cancel_reason")

  createdBy       User            @relation("PrCreatedBy", fields: [createdById], references: [id])
  responsible     Employee?       @relation("PrResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  approver        User?           @relation("PrApprover", fields: [approverId], references: [id], onDelete: SetNull)
  items           PrItem[]
  comments        PrComment[]
  activities      PrActivity[]
  checklists      PrChecklist[]
  attachments     PrAttachment[]

  @@index([status])
  @@index([createdById])
  @@index([responsibleId])
  @@index([dueDate])
  @@map("purchase_requests")
}

model PrItem {
  id        String   @id @default(cuid())
  prId      String   @map("pr_id")
  name      String
  detail    String?  @db.Text
  qty       Decimal  @db.Decimal(10, 2)
  unit      String?
  budget    Decimal? @db.Decimal(14, 2)
  neededBy  DateTime? @map("needed_by") @db.Date

  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@map("pr_items")
}

model PrComment {
  id        String   @id @default(cuid())
  prId      String   @map("pr_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  user      User            @relation("PrComment", fields: [userId], references: [id])

  @@index([prId])
  @@map("pr_comments")
}

model PrActivity {
  id        String   @id @default(cuid())
  prId      String   @map("pr_id")
  userId    String   @map("user_id")
  action    String   // status_change|comment|edit|attachment|assign|approve|cancel
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  user      User            @relation("PrActivity", fields: [userId], references: [id])

  @@index([prId])
  @@index([createdAt])
  @@map("pr_activities")
}

model PrChecklist {
  id        String    @id @default(cuid())
  prId      String    @map("pr_id")
  label     String
  isDone    Boolean   @default(false) @map("is_done")
  doneAt    DateTime? @map("done_at")
  doneById  String?   @map("done_by_id")
  sortOrder Int       @default(0) @map("sort_order")

  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@map("pr_checklists")
}

model PrAttachment {
  id           String   @id @default(cuid())
  prId         String   @map("pr_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  pr           PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@map("pr_attachments")
}

// Sequence counter for PR number
model PrSequence {
  id      String @id @default("singleton")
  lastSeq Int    @default(0) @map("last_seq")
  year    Int

  @@map("pr_sequence")
}

// ============================================================
// Document Center — SVA | SVR | MPA (unified)
// ============================================================
model DocumentRecord {
  id             String   @id @default(cuid())
  docType        String   @map("doc_type")   // sva | svr | mpa
  docNumber      String?  @unique @map("doc_number") // DOC-2026-07-SVA-001
  month          Int
  year           Int
  version        Int      @default(1)
  status         String   @default("draft")  // draft|pending_review|pending_approval|approved|signing|completed|cancelled
  requiredSigners String[] @default(["employee","supervisor"]) @map("required_signers")
  companyName    String   @default("บริษัท ทีทีจี โฮลดิ้ง จำกัด") @map("company_name")
  declaration    String?
  notes          String?
  // KPI targets
  kpiSiteVisit   Int?     @map("kpi_site_visit")
  kpiFollowup    Int?     @map("kpi_followup")
  kpiNewAgency   Int?     @map("kpi_new_agency")
  kpiTraining    Int?     @map("kpi_training")
  kpiSales       Int?     @map("kpi_sales")
  // Actual results (SVR/MPA)
  actualSiteVisit  Int?   @map("actual_site_visit")
  actualFollowup   Int?   @map("actual_followup")
  actualNewAgency  Int?   @map("actual_new_agency")
  actualTraining   Int?   @map("actual_training")
  actualSales      Int?   @map("actual_sales")
  // Stats (SVR/MPA)
  workingDays    Int?     @map("working_days")
  leaveDays      Int?     @map("leave_days")
  gpsCompliancePct Int?   @map("gps_compliance_pct")
  photoCompliancePct Int? @map("photo_compliance_pct")
  // Evaluations
  supervisorScore   Int?  @map("supervisor_score")
  supervisorComment String? @map("supervisor_comment")
  supervisorPlan    String? @map("supervisor_plan")
  employeeComment   String? @map("employee_comment")
  aiAnalysis        Json?   @map("ai_analysis")
  // Relations
  employeeId     String   @map("employee_id")
  employee       Employee @relation(fields: [employeeId], references: [id])
  supervisorId   String?  @map("supervisor_id")
  supervisor     User?    @relation("DocSupervisor", fields: [supervisorId], references: [id])
  closerId       String?  @map("closer_id")
  closer         User?    @relation("DocCloser", fields: [closerId], references: [id])
  approvedById   String?  @map("approved_by_id")
  approvedBy     User?    @relation("DocApprover", fields: [approvedById], references: [id])
  createdById    String   @map("created_by_id")
  createdBy      User     @relation("DocCreator", fields: [createdById], references: [id])
  approvedAt     DateTime? @map("approved_at")
  effectiveAt    DateTime? @map("effective_at")
  rows       DocRow[]
  signatures DocSignature[]
  auditLogs  DocAuditLog[]
  versions   DocVersion[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([docType, year, month])
  @@index([employeeId])
  @@index([status])
  @@map("document_records")
}

model DocRow {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  document     DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)
  rowType      String   @default("schedule") @map("row_type") // schedule | kpi | activity
  sortOrder    Int      @default(0) @map("sort_order")
  // Schedule fields (SVA/SVR)
  visitDate    DateTime? @map("visit_date")
  visitTime    String?   @map("visit_time")
  agencyId     String?   @map("agency_id")
  agencyName   String?   @map("agency_name")
  contactPerson String?  @map("contact_person")
  province     String?
  visitType    String?   @default("site_visit") @map("visit_type")
  priority     String?   @default("medium")
  status       String?   @default("scheduled")
  plannedTime  String?   @map("planned_time")
  actualTime   String?   @map("actual_time")
  result       String?
  // KPI row (MPA)
  kpiName      String?   @map("kpi_name")
  kpiTarget    Int?      @map("kpi_target")
  kpiActual    Int?      @map("kpi_actual")
  // Activity row (SVR)
  activityName String?   @map("activity_name")
  activityDone Boolean?  @default(false) @map("activity_done")
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("doc_rows")
}

model DocSignature {
  id            String   @id @default(cuid())
  documentId    String   @map("document_id")
  document      DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerType    String   @map("signer_type") // employee | supervisor | manager | executive
  signedById    String   @map("signed_by_id")
  signedBy      User     @relation("DocSignatureUser", fields: [signedById], references: [id])
  signedAt      DateTime @default(now()) @map("signed_at")
  signatureData String   @db.Text @map("signature_data")
  revokedAt     DateTime? @map("revoked_at")
  revokeReason  String?   @map("revoke_reason")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("doc_signatures")
}

model DocAuditLog {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  document     DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action       String
  actorId      String   @map("actor_id")
  actor        User     @relation("DocAuditActor", fields: [actorId], references: [id])
  detail       Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("doc_audit_logs")
}

model DocVersion {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  document     DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  snapshot     Json
  reason       String?
  createdById  String   @map("created_by_id")
  createdBy    User     @relation("DocVersionCreator", fields: [createdById], references: [id])
  approvedById String?  @map("approved_by_id")
  approvedBy   User?    @relation("DocVersionApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("doc_versions")
}

// ============================================================
// Enterprise Extension Models
// ============================================================

model Region {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  branches  Branch[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("regions")
}

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  regionId  String?  @map("region_id")
  region    Region?  @relation(fields: [regionId], references: [id])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([regionId])
  @@map("branches")
}

model Department {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  managerId String?  @map("manager_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("departments")
}

model ExpenseReport {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  visitPlanId String?  @map("visit_plan_id")
  date        DateTime @db.Date
  category    String   @default("other") // fuel | food | accommodation | other
  amount      Decimal  @db.Decimal(10,2)
  description String?
  receiptUrl  String?  @map("receipt_url")
  status      String   @default("pending") // pending | approved | rejected
  approvedById String? @map("approved_by_id")
  approvedBy  User?    @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt  DateTime? @map("approved_at")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([employeeId])
  @@index([status])
  @@index([date])
  @@map("expense_reports")
}

model TrainingRecord {
  id           String   @id @default(cuid())
  employeeId   String   @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id])
  trainingName String   @map("training_name")
  description  String?
  trainingDate DateTime @db.Date @map("training_date")
  hours        Int?
  score        Int?
  passed       Boolean  @default(false)
  certificate  String?
  notes        String?
  createdById  String   @map("created_by_id")
  createdBy    User     @relation("TrainingCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([employeeId])
  @@map("training_records")
}

model EmployeeEvaluation {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id])
  month         Int
  year          Int
  kpiScore      Int?     @map("kpi_score")
  behaviorScore Int?     @map("behavior_score")
  overallScore  Int?     @map("overall_score")
  grade         String?  // A B C D
  strengths     String?
  improvements  String?
  goals         String?
  evaluatedById String   @map("evaluated_by_id")
  evaluatedBy   User     @relation("EvaluationCreator", fields: [evaluatedById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  @@unique([employeeId, year, month])
  @@index([employeeId])
  @@map("employee_evaluations")
}

model AgencyScore {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  agency       Agency   @relation(fields: [agencyId], references: [id])
  month        Int
  year         Int
  visitScore   Int?     @map("visit_score")
  salesScore   Int?     @map("sales_score")
  growthScore  Int?     @map("growth_score")
  riskScore    Int?     @map("risk_score")
  overallScore Int?     @map("overall_score")
  grade        String?
  notes        String?
  createdById  String   @map("created_by_id")
  createdBy    User     @relation("AgencyScoreCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  @@unique([agencyId, year, month])
  @@index([agencyId])
  @@map("agency_scores")
}

model ApprovalRule {
  id          String   @id @default(cuid())
  module      String   // leave | pr | agency | document | expense
  minAmount   Decimal? @db.Decimal(12,2) @map("min_amount")
  maxAmount   Decimal? @db.Decimal(12,2) @map("max_amount")
  level1Role  String   @default("closer") @map("level1_role")
  level2Role  String?  @map("level2_role")
  level3Role  String?  @map("level3_role")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("approval_rules")
}

model MasterData {
  id        String   @id @default(cuid())
  category  String   // visit_type | task_type | reason_code | agency_type | priority
  code      String
  nameEn    String   @map("name_en")
  nameTh    String   @map("name_th")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([category, code])
  @@index([category])
  @@map("master_data")
}

// ============================================================
// Broadcast Center
// ============================================================
model Broadcast {
  id              String   @id @default(cuid())
  title           String
  type            String   @default("news")  // news/announcement/promotion/hr/it/training/emergency
  priority        String   @default("normal") // low/normal/high/critical
  content         String   @db.Text
  imageUrl        String?  @map("image_url")
  buttons         Json?    // [{label, url}]
  recipientType   String   @default("all")   @map("recipient_type") // all/sale/closer/admin/executive/individual
  recipientIds    String[] @map("recipient_ids")
  recipientFilter Json?    @map("recipient_filter") // {zone?, teamId?}
  scheduleType    String   @default("immediate") @map("schedule_type") // immediate/scheduled/recurring
  scheduledAt     DateTime? @map("scheduled_at")
  recurringFreq   String?  @map("recurring_freq")  // daily/weekly/monthly
  recurringDay    Int?     @map("recurring_day")
  recurringTime   String?  @map("recurring_time")  // "08:30"
  recurringUntil  DateTime? @map("recurring_until")
  status          String   @default("draft") // draft/pending_approval/approved/scheduled/sending/sent/failed/cancelled
  sentCount       Int      @default(0) @map("sent_count")
  deliveredCount  Int      @default(0) @map("delivered_count")
  readCount       Int      @default(0) @map("read_count")
  clickCount      Int      @default(0) @map("click_count")
  failedCount     Int      @default(0) @map("failed_count")
  approvalRequired Boolean @default(false) @map("approval_required")
  approvedById    String?  @map("approved_by_id")
  approvedBy      User?    @relation("BroadcastApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime? @map("approved_at")
  rejectedReason  String?  @map("rejected_reason")
  createdById     String   @map("created_by_id")
  createdBy       User     @relation("BroadcastCreator", fields: [createdById], references: [id])
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  recipients      BroadcastRecipient[]
  logs            BroadcastLog[]
  @@index([status])
  @@index([createdById])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String    @map("broadcast_id")
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id])
  lineUserId  String    @map("line_user_id")
  status      String    @default("pending") // pending/sent/failed
  sentAt      DateTime? @map("sent_at")
  error       String?
  @@unique([broadcastId, employeeId])
  @@map("broadcast_recipients")
}

model BroadcastTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("news")
  content     String   @db.Text
  buttons     Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("broadcast_templates")
}

model BroadcastLog {
  id          String    @id @default(cuid())
  broadcastId String    @map("broadcast_id")
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  action      String    // created/edited/approved/rejected/sent/cancelled/deleted
  userId      String?   @map("user_id")
  user        User?     @relation("BroadcastLogUser", fields: [userId], references: [id])
  detail      String?
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("broadcast_logs")
}
