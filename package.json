{
  "name": "agency-care",
  "version": "0.1.0",
  "private": true,
  "description": "Agency Care Enterprise — ระบบดูแล/เข้าเยี่ยม Agency ภาคสนาม (MVP เฟส 1)",
  "scripts": {
    "dev": "pnpm --parallel --filter ./api --filter ./web dev",
    "dev:api": "pnpm --filter ./api dev",
    "dev:web": "pnpm --filter ./web dev",
    "build": "pnpm --filter ./shared build && pnpm --filter ./api build && pnpm --filter ./web build",
    "db:migrate": "pnpm --filter ./api prisma:migrate",
    "db:seed": "pnpm --filter ./api prisma:seed",
    "db:import": "pnpm --filter ./api prisma:import",
    "db:studio": "pnpm --filter ./api prisma:studio"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0"
}
