# ===== Database (Neon) =====
# คัดลอก connection string จาก Neon dashboard มาวางตรงนี้
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# ===== API =====
API_PORT=3000
# allow origin ของ web (Vite dev server)
CORS_ORIGIN="http://localhost:5173"

# ===== Auth (JWT) =====
# สร้างค่าสุ่มยาว ๆ เช่น: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ===== LINE Messaging API (แจ้งเตือนเซลส์) =====
# Channel access token (long-lived) จาก LINE Developers > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=""
# เปิด cron แจ้งเตือนรายวัน 08:00 (Asia/Bangkok)
NOTIFY_ENABLED="false"

# ===== AI Analytics (Claude) =====
# API key จาก console.anthropic.com — ใช้ model claude-opus-4-8 วิเคราะห์ข้อมูลทีมขาย
ANTHROPIC_API_KEY=""

# ===== Google Maps (bulk geocode พิกัด agency) =====
# เปิด Places API + Geocoding API ใน Google Cloud แล้วใส่ API key
GOOGLE_MAPS_API_KEY=""

# ===== Visit / Check-in =====
# รัศมีสูงสุด (เมตร) ที่อนุญาตให้ check-in ได้ เกินกว่านี้ระบบปฏิเสธ
CHECKIN_MAX_RADIUS_METERS=200
# โฟลเดอร์เก็บรูป (MVP เก็บใน local disk; เฟสหลังย้ายขึ้น S3/Cloud Storage)
UPLOAD_DIR="uploads"

# ===== Seed (admin user แรก) =====
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin@1234"

# ===== Web (Vite) — ใส่ใน web/.env ด้วย (prefix VITE_) =====
VITE_API_BASE_URL="http://localhost:3000"
